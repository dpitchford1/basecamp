# Wordpress - ignore core, configuration, examples, uploads and logs.
# https://github.com/github/gitignore/blob/main/WordPress.gitignore

# Core
#
# Note: if you want to stage/commit WP core files
# you can delete this whole section/until Configuration.
/wp-admin/
/wp-content/index.php
/wp-content/languages
/wp-content/plugins/index.php
/wp-content/themes/index.php
/wp-includes/
/index.php
/license.txt
/readme.html
/wp-*.php
/xmlrpc.php
.gitignore
basecamp.code-workspace
*.DS_Store
.vscode/
.github/

# Configuration
wp-config.php

# Example themes
/wp-content/themes/twenty*/

# Personal Child Themes
/wp-content/themes/dish/
/wp-content/themes/miconcept-design/

# General theme(s) files
/wp-content/themes/basecamp/inc/admin/assets/
/_old-dish-files/
/assets/_archive/

#/wp-content/themes/basecamp/templates/
/wp-content/themes/basecamp/inc/*archive/
/wp-content/themes/basecamp/inc/woocommerce/

# WP plugins
/wp-content/plugins/_archive
/wp-content/plugins/hello.php
/wp-content/plugins/classic-editor/
/wp-content/plugins/contact-form-7/
/wp-content/plugins/contact-form-7-honeypot/
/wp-content/plugins/menus/
/wp-content/plugins/wp-sweep/

# Personal plugins
/wp-content/plugins/dev-maintenance/
/wp-content/plugins/layout-tester/
/wp-content/plugins/work/
/wp-content/plugins/faqs/
/wp-content/plugins/media-library-plus/
/wp-content/plugins/dish-events/

# Uploads
/wp-content/uploads/
/wp-content/mu-pluginsX/

# Log files
*.log

# htaccess
/.htaccess

